# Backend (local host urls — docker-compose overrides service urls internally)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/k8s_security
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=dev-secret-change-me
API_PORT=8000

# AWS / GuardDuty (leave disabled for local)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
GUARDDUTY_DETECTOR_ID=

# Kubernetes
KUBECONFIG_PATH=/etc/kubeconfig
K8S_NAMESPACE=security-dashboard

# Falco
FALCO_GRPC_ENDPOINT=localhost:5060

# Feature flags
ENABLE_GUARDDUTY=false
ENABLE_MOCK_DATA=true
